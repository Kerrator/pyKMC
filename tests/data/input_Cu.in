[Control] 
initial_config = ./initial_config.xyz 
n_steps = 50
engine = lammps
verbosity = 2
n_sessions = 7
engine_use_rank_0 = False
reference_table = reference_table_fake.pickle 
visited_environments = visited_environments.pickle
reference_table_output = a.pickle

[Lammps] 
pair_style = eam/alloy 
pair_coeff = * * ./tests/data/Cu01.eam.alloy Cu
min_style = cg 
minimize = 1e-10 1e-12 10000 10000

[AtomicEnvironment] 
style = cna/graph
rnei = 2.9
rcut = 6.5

[EventSearch] 
style = partn
nsearch = 20
emax_event = 5.0
emin_event = 0.0

[pARTn] 
forc_thr = 0.001

[RateConstant] 
style = constant
k0 = 1.0
T = 300.0

[PSR] 
style = ira 
matching_score_thr = 0.4

[IRA]
kmax_factor = 2.0

[BASIN]
energy_thr = 0.5
