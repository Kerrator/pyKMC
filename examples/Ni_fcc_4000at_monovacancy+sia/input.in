[Control] 
initial_config = ./initial_config.xyz 
n_steps = 5
engine = lammps
verbosity = 2
reference_table = reference_table.pickle
visited_environments = visited_environments.pickle

[Lammps] 
pair_style = eam/alloy 
pair_coeff = * * ./Ni_v6_2.0_LKBeland2016.eam Ni

[AtomicEnvironment] 
style = cna/graph
rnei = 3.01
rcut = 8.0
neighbors_add = 1

[EventSearch] 
style = partn
rcutenv = 6.5
nsearch = 10
path_artnso = /root/programs/artn-plugin/lib/libartn-lmp.so
emax_event = 5.0
emin_event = 0.0
partn_delr_threshold = 0.4

[pARTn] 
path_artnso = /root/programs/artn-plugin/lib/libartn-lmp.so

[RateConstant] 
style = constant
k0 = 1.0e12
T = 300.0

[PSR] 
style = ira 
matching_score_thr = 0.3

[IRA]
kmax_factor = 2.0
