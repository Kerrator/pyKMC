[Control] 
initial_config = /root/pyKMC/examples/Ni_fcc_2047at_monovacancy/initial_config.xyz 
n_steps = 1
engine = lammps
#n_sessions = 1
#engine_use_rank_0 = True
verbosity = 2
#reference_table = reference_table.pickle
#visited_environments =visited_environments.pickle

[Lammps] 
pair_style = eam/alloy 
pair_coeff = * * ./Ni_v6_2.0_LKBeland2016.eam Ni

[AtomicEnvironment] 
style = cna/graph
rnei = 3.01
rcut = 6.0

[EventSearch] 
style = partn
nsearch = 20
emax_event = 5.0
emin_event = 0.0

[pARTn] 
path_artnso = /root/programs/artn-plugin/lib/libartn-lmp.so

[RateConstant] 
style = constant
k0 = 1
T = 300.0

[PSR] 
style = ira 
[IRA]
