[Control] 
initial_config = ./initial_config.xyz 
n_steps = 20
engine = lammps
verbosity = 2
n_sessions = 7
engine_use_rank_0 = False


[Lammps] 
pair_style = eam/alloy 
pair_coeff = * * FeC-Becquart2013.eam Fe
min_style = cg 
minimize = 1e-10 1e-12 1000 1000

[AtomicEnvironment] 
style = cna/graph
rnei = 2.8
rcut = 6.0
neighbors_add = 1

[EventSearch] 
style = partn
nsearch = 10
emax_event = 5.0
emin_event = 0.0

[pARTn] 
path_artnso = /root/programs/artn-plugin/lib/libartn-lmp.so

[RateConstant] 
style = constant
k0 = 10
T = 300.0

[PSR] 
style = ira 
matching_score_thr = 0.3

[IRA]
kmax_factor = 2.0

[Basin]
