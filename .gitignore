# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.pytest_cache/

# Tests — whitelist everything, then re-ignore generated files
*test*
!tests/
!tests/**/*
tests/**/__pycache__/
tests/**/*.py[cod]

# Examples — ignore everything except source files
examples/**
!examples/**/*.in
!examples/**/initial_config.xyz

# Benchmarks — keep only scripts
benchmarks/**
!benchmarks/*/
!benchmarks/**/*.py
!benchmarks/**/*.sh

# Utils
utils/analyse/*.xyz

# LAMMPS / simulation outputs
*core
!**/_core/
!**/_core/**
log.lammps
pykmc.*

# IDE
.vscode/**
.idea/**
.claude/**

# OS
.DS_Store
