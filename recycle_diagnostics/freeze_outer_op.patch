+def minimize_freeze_outer_with_results(engine, config, positions=None, types=None,
+                                       central_atom=None, rmov=None) :
+    """Local reconstruction minimize: relax only atoms within ``rmov`` of
+    ``central_atom`` (outer sphere zero-forced), then return positions + energy.
+
+    Full-cell counterpart of :func:`minimize_with_results` for event
+    reconstruction. Freezing the far field removes the thousands of soft
+    collective DOFs whose unconstrained relaxation lets a transplanted saddle
+    shell drift into the wrong basin / lose atoms at scale.
+    """
+    if positions is not None :
+        _require_finite_positions(positions, "minimize_freeze_outer_with_results")
+        set_positions(engine=engine, positions=positions)
+    raw = engine.lmp.gather_atoms("x", 1, 3)
+    cur = np.ctypeslib.as_array(raw).reshape(-1, 3)
+    boxlo, boxhi, _xy, _yz, _xz, periodicity, _change = engine.lmp.extract_box()
+    cell = np.diag(np.asarray(boxhi, dtype=float) - np.asarray(boxlo, dtype=float))
+    pbc = [bool(p) for p in periodicity]
+    _minimize_freeze_outer_sphere(engine, config, cur, int(central_atom), float(rmov), cell, pbc)
+    new_positions = get_positions(engine)
+    total_energy = get_total_energy(engine)
+    if engine.rank == 0 :
+        return new_positions, total_energy
